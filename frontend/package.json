{
  "name": "yen-go",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node -e \"require('fs').copyFileSync('node_modules/sql.js/dist/sql-wasm.wasm','public/sql-wasm.wasm')\"",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:preview": "npm run build && npm run preview",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:regression": "vitest run tests/regression/",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:visual": "playwright test --config playwright.config.ts",
    "test:visual:update": "playwright test --config playwright.config.ts --update-snapshots",
    "test:visual:ui": "playwright test --config playwright.config.ts --ui",
    "test:e2e": "playwright test --config playwright.e2e.config.ts",
    "test:e2e:ui": "playwright test --config playwright.e2e.config.ts --ui",
    "test:all": "npm test && npm run test:visual && npm run test:e2e",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@preact/compat": "^18.3.1",
    "@tailwindcss/vite": "^4.1.18",
    "autoprefixer": "^10.4.24",
    "goban": "^8.3.147",
    "postcss": "^8.5.6",
    "sql.js": "^1.11.0",
    "preact": "^10.19.3",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@preact/preset-vite": "^2.8.2",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-preact": "^0.1.0",
    "jsdom": "^23.0.1",
    "prettier": "^3.1.0",
    "sirv": "^3.0.2",
    "typescript": "^5.3.2",
    "vite": "^5.0.7",
    "vite-plugin-pwa": "^0.17.4",
    "vitest": "^1.1.0",
    "workbox-window": "^7.0.0"
  }
}
