{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",

    /* Strict mode - NON-NEGOTIABLE per Constitution */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Paths */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@services/*": ["src/services/*"],
      "@models/*": ["src/models/*"],
      "@hooks": ["src/hooks"],
      "@hooks/*": ["src/hooks/*"],
      "@styles/*": ["src/styles/*"],
      "@utils/*": ["src/utils/*"],
      "@lib/*": ["src/lib/*"],
      "@types/*": ["src/types/*"],
      "@config/*": ["src/config/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "src/pages/PuzzleView/**",
    "src/pages/HomePage.tsx",
    "src/pages/PuzzleSolvePage.tsx",
    "src/pages/StatsPage.tsx",
    "src/pages/AchievementsPage.tsx",
    "src/pages/ReviewPage.tsx",
    "src/components/ChallengeList/**",
    "src/components/Level/PuzzleGrid.tsx",
    "src/hooks/usePaginatedPuzzles.ts",
    "src/lib/puzzle/pagination.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
