# Puzzle Manager - Dynamic state files (not version controlled)
puzzle_manager/state/
puzzle_manager/staging/
puzzle_manager/logs/

# KataGo log directory if CWD guard fails (should land in tool dir, not repo root)
analysis_logs/

# Runtime artifacts for puzzle_manager (logs, state, staging)
# Created at project root, separate from source code
/.pm-runtime/

# Claude Agent temporary directories
tmpclaude-*-cwd
NUL

# Scratch/temporary files (underscore-prefixed at repo root)
/_*

