# yen-sei: do not commit generated data — only code, config, and docs.
# These are produced by `qualify`, `ingest`, `harvest`, `refine` and can be
# regenerated by re-running the pipeline. Committing them would bloat the
# repo and create merge conflicts on every run.

# Generated by qualify
data/qualification_v2.jsonl
data/qualification_v2_report.txt
data/qualification_v2*.jsonl
data/qualification_v2*.txt
data/_preview*.jsonl
data/_preview*.txt
data/qualify_run.log

# Generated by ingest (copied SGFs + manifest)
data/sources/

# Generated by harvest (raw extracts)
data/raw/

# Generated by refine (SFT JSONL output)
data/refined/

# Python
__pycache__/
*.pyc
.pytest_cache/
