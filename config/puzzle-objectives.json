{
  "$schema": "./schemas/puzzle-objectives.schema.json",
  "schema_version": "2.5",
  "description": "Canonical puzzle objective definitions mapping SGF comment patterns to structured objectives with category, side, type, and engine-verifiability. Used by tools/puzzle_intent for intent extraction.",
  "last_updated": "2026-03-26",
  "precision_mode": "strict",
  "changelog": [
    {
      "version": "2.5",
      "date": "2026-03-26",
      "author": "config-standardization",
      "changes": "Added $schema, description, and last_updated metadata fields to match project config conventions."
    },
    {
      "version": "2.4",
      "date": "2026-03-09",
      "author": "senseis-library-enrichment",
      "changes": "Added Sensei's Library cross-referenced aliases: CAPTURE objectives gained 'to take'/'take stones'; WIN_SEMEAI objectives gained 'wins the liberty count'. Total aliases ~170+."
    },
    {
      "version": "2.3",
      "date": "2026-03-02",
      "author": "chinese-alias-enrichment",
      "changes": "Added Chinese puzzle-catalogue derived aliases from Baidu/101Weiqi taxonomy: capture objectives gained 'eat' surface forms (bao chi translations); semeai objectives gained 'fight'/'race' phrasings; ko objectives gained 'robbery' phrasings; life-and-death objectives gained 'make life' and side-explicit life/death phrasings. All aliases conform to pattern ^[a-z0-9 '-]+$."
    },
    {
      "version": "2.2",
      "date": "2026-02-13",
      "author": "slug-name-enrichment",
      "changes": "Added slug (kebab-case backend identifier) and name (human-readable frontend label) to all 23 objectives. Naming follows standard Go literature conventions (e.g. 'Black to Play', 'Black to Live')."
    },
    {
      "version": "2.1",
      "date": "2026-02-13",
      "author": "alias-expansion",
      "changes": "Expanded aliases for underrepresented objectives (ESCAPE, CONNECT, CUT, SEMEAI, KO, SEKI). Added common wild-phrasing variants. Total aliases ~160+."
    },
    {
      "version": "2.0",
      "date": "2026-02-12",
      "author": "expert-review",
      "changes": "Expert-reviewed expansion: 17->23 objectives. Added ESCAPE (distinct from LIVE), TESUJI (generic tactical), ENDGAME (yose) objectives. Expanded aliases from ~40 to ~100+ including romanized CJK terms. Added changelog for auditability."
    },
    {
      "version": "1.0",
      "date": "2026-02-12",
      "author": "initial",
      "changes": "Initial schema: 17 objectives across 5 categories (MOVE_ORDER, LIFE_AND_DEATH, CAPTURING, SHAPE, FIGHT) with ~40 aliases."
    }
  ],
