{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://yen-go.github.io/schemas/quality.schema.json",
  "title": "Quality Configuration Schema",
  "description": "Schema for puzzle quality tier definitions in Yen-Go",
  "type": "object",
  "required": ["schema_version", "tiers", "display"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this schema file"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Config format version (MAJOR.MINOR)"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of this config file"
    },
    "last_updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO date of last modification (YYYY-MM-DD)"
    },
    "changelog": {
      "type": "array",
      "description": "Version history for auditability.",
      "items": {
        "type": "object",
        "required": ["version", "date", "author", "changes"],
        "additionalProperties": false,
        "properties": {
          "version": { "type": "string" },
          "date": { "type": "string" },
          "author": { "type": "string" },
          "changes": { "type": "string" }
        }
      }
    },
    "tiers": {
      "type": "object",
      "description": "Quality tier definitions keyed by tier number (1-5)",
      "propertyNames": {
        "pattern": "^[1-5]$"
      },
      "additionalProperties": {
        "$ref": "#/definitions/tierDefinition"
      },
      "minProperties": 5,
      "maxProperties": 5
    },
    "display": {
      "type": "object",
      "description": "Display configuration for quality indicators",
      "required": ["star_colors", "tier_colors"],
      "properties": {
        "star_colors": {
          "type": "object",
          "required": ["filled", "empty"],
          "properties": {
            "filled": {
              "type": "string",
              "pattern": "^#[0-9A-Fa-f]{6}$",
              "description": "Hex color for filled stars"
            },
            "empty": {
              "type": "string",
              "pattern": "^#[0-9A-Fa-f]{6}$",
              "description": "Hex color for empty stars"
            }
          }
        },
        "tier_colors": {
          "type": "object",
          "description": "Hex colors for each tier indicator",
          "propertyNames": {
            "pattern": "^[1-5]$"
          },
          "additionalProperties": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          }
        }
      }
    }
  },
  "definitions": {
    "tierDefinition": {
      "type": "object",
      "required": ["name", "display_label", "stars", "description", "requirements", "selection_weight"],
      "properties": {
        "name": {
          "type": "string",
          "enum": ["premium", "high", "standard", "basic", "unverified"],
          "description": "Machine-readable tier name (slug)"
        },
        "display_label": {
          "type": "string",
          "description": "Human-readable tier label for UI"
        },
        "stars": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "Number of stars to display (1-5)"
        },
        "description": {
          "type": "string",
          "description": "Tooltip/help text explaining the tier"
        },
        "requirements": {
          "type": "object",
          "description": "Criteria for assigning this tier",
          "properties": {
            "refutation_count_min": {
              "type": "integer",
              "minimum": 0,
              "description": "Minimum number of refutation branches required"
            },
            "has_comments": {
              "type": "boolean",
              "description": "Whether comments are required"
            },
            "has_solution_tree": {
              "type": "boolean",
              "description": "Whether a solution tree is required"
            }
          }
        },
        "selection_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Weight multiplier for daily challenge selection"
        }
      }
    }
  }
}
