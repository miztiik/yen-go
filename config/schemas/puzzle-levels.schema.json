{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://yen-go.github.io/schemas/puzzle-levels.schema.json",
  "title": "Puzzle Levels Configuration",
  "description": "Schema for config/puzzle-levels.json — 9-level difficulty system for puzzle classification. Sparse IDs aligned to Go rank ranges (kyu=100s, dan=200s).",
  "type": "object",
  "required": ["schema_version", "description", "last_updated", "frozen", "levels"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this schema file"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Schema version (MAJOR.MINOR)"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of this config file"
    },
    "last_updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO date of last modification (YYYY-MM-DD)"
    },
    "changelog": {
      "type": "array",
      "description": "Version history for auditability.",
      "items": {
        "type": "object",
        "required": ["version", "date", "author", "changes"],
        "additionalProperties": false,
        "properties": {
          "version": { "type": "string" },
          "date": { "type": "string" },
          "author": { "type": "string" },
          "changes": { "type": "string" }
        }
      }
    },
    "frozen": {
      "type": "boolean",
      "description": "If true, the level set is locked and must not be changed without migration"
    },
    "levels": {
      "type": "array",
      "description": "Ordered list of difficulty levels from easiest to hardest",
      "items": {
        "$ref": "#/definitions/LevelDefinition"
      },
      "minItems": 1
    }
  },
  "additionalProperties": false,
  "definitions": {
    "LevelDefinition": {
      "type": "object",
      "required": ["id", "slug", "name", "shortName", "rankRange", "description"],
      "properties": {
        "id": {
          "type": "integer",
          "description": "Sparse numeric ID. Kyu range: 110-160, Dan range: 210-230"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Kebab-case identifier for URLs and config references"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable display name"
        },
        "shortName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 5,
          "description": "Abbreviated name for compact display (e.g. 'Nov', 'Beg')"
        },
        "rankRange": {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": {
              "type": "string",
              "pattern": "^\\d+[kd]$",
              "description": "Minimum rank (e.g. '30k', '1d')"
            },
            "max": {
              "type": "string",
              "pattern": "^\\d+[kd]$",
              "description": "Maximum rank (e.g. '26k', '3d')"
            }
          },
          "additionalProperties": false
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Brief description of the difficulty level"
        }
      },
      "additionalProperties": false
    }
  }
}
