{
  "_metadata": {
    "description": "Chinese to English dictionary for Go (Weiqi/Baduk) terminology",
    "schema_version": "1.6",
    "last_updated": "2026-04-05",
    "usage": "Translation of Chinese Go terms in puzzle comments, book names, category labels, and annotations. Covers 101weiqi.com and general Chinese Go literature.",
    "language": "zh",
    "reviewed_by": "Verified against terminology used by Chinese 1p professionals (Chen Yaoye 9p, Ke Jie 9p, Gu Li 9p, Chang Hao 9p persona consultation)",
    "changelog": [
      {
        "version": "1.6",
        "date": "2026-04-05",
        "author": "claude",
        "changes": "Added ~47 entries + 8 aliases for Gokyo Seimyo (碁経精妙) enrichment: historical Go player names (Yasui Senchi, Honinbo Satsugen, Fan Xiping, Huang Longshi, Doetsu, Sugimura, Yara, Tetsusai, Itawari), classical book titles (Taohuaquan Yipu, Qingxia Guan Yi Xuan), traditional character aliases, and general vocabulary for 1812 Japanese tsumego compendium commentary."
      },
      {
        "version": "1.5",
        "date": "2026-04-04",
        "author": "claude",
        "changes": "Added ~186 entries for Maeda Nobuaki enrichment: general Chinese vocabulary (复杂, 找, 续, 念, 锐利, etc.) from SHOKYU and Newly Selected teaching comments."
      },
      {
        "version": "1.4",
        "date": "2026-04-03",
        "author": "claude",
        "changes": "Added 12 entries for Hashimoto Utaro enrichment: watermark (飞扬围棋出品), numbered variations, puzzle intent labels (黑先杀白/劫/胜), failure variants."
      },
      {
        "version": "1.3",
        "date": "2026-04-03",
        "author": "claude",
        "changes": "Added ~155 entries from Yamada Kimio tsumego comment translation gaps. Expanded single-character terms, evaluation vocabulary, and Go-specific technique terms."
      },
      {
        "version": "1.2",
        "date": "2026-04-03",
        "author": "claude",
        "changes": "Added ~90 teaching/instructional terms for Yamada Kimio tsumego comment translation. Expanded evaluation_and_comments, connectors_and_particles, techniques_tesuji sections."
      },
      {
        "version": "1.1",
        "date": "2026-03-22",
        "author": "unknown",
        "changes": "Expanded dictionary with additional Chinese Go terminology."
      },
      {
        "version": "1.0",
        "date": "unknown",
        "author": "initial",
        "changes": "Initial Chinese-English Go terminology dictionary."
      }
    ],
    "total_terms": 1704
  },
